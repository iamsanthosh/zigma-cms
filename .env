# ---- MySQL (Hostinger managed MySQL) ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=zigma
DB_PASSWORD=devpassword
DB_NAME=zigma

# ---- Auth ----
JWT_SECRET=ca4c1e2565acf6a30c27708e578e6682d5996a73641d40d2f5af1d94b40f94f8
JWT_EXPIRES_IN=7d
COOKIE_NAME=zigma_admin
# When NODE_ENV is not "production" (e.g. `npm run dev`), the admin panel
# skips login entirely and treats you as a logged-in admin — set this to
# "false" locally if you specifically want to exercise the real login flow.
# This flag has no effect at all when NODE_ENV=production.
DEV_BYPASS_AUTH=true
NODE_ENV=development

# ---- Admin User (for db:setup script) ----
ADMIN_NAME="Admin User"
ADMIN_EMAIL="admin@zigma.com"
ADMIN_PASSWORD="StrongPass123!"

# ---- Media ----
# Local uploads live in /public/uploads and are served directly by Next.js on
# Hostinger. If you later move to an external CDN/object store, set this to
# the base URL your MediaPicker + upload route should write into instead.
MEDIA_BASE_URL=/uploads

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://zigma-technologies.com
